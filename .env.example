# ===== Feishu App Config =====
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ===== Claude Code CLI =====
CLAUDE_CLI_PATH=claude
CLAUDE_DEFAULT_MODEL=sonnet

# ===== Profile Switching =====
# Provider profiles are stored as settings_*.json in ~/.claude/
# Use /switch command in Feishu to switch between providers (GLM, Kimi, etc.)

# ===== Workspace =====
DEFAULT_WORKSPACE=D:\\projects

# ===== Approval Config =====
APPROVAL_TIMEOUT=600
# Default approval mode: h=高容忍(全允许) m=中(高风险审批) l=低(全审批)
APPROVAL_MODE=m

# ===== Hook Config (used by scripts/hooks/pre_tool_use.py) =====
OPENCLAW_HOST=localhost
OPENCLAW_PORT=8080

# ===== Access Control =====
ALLOWED_USERS=ou_xxxxxxxxxxxxxxxx,ou_xxxxxxxxxxxxxxxx

# ===== Audit Config =====
AUDIT_LOG_PATH=./audit.log

# ===== Server Config =====
HOST=0.0.0.0
PORT=8080
